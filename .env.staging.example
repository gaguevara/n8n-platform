# .env.staging.example — Variables de entorno para el servidor Dell R720
# Copiar como .env en el servidor: cp .env.staging.example .env
# NUNCA commitear el .env real

# --- GENERAL ---
TZ=America/Bogota
GENERIC_TIMEZONE=America/Bogota
N8N_PORT=5678

# --- SEGURIDAD (CRÍTICO) ---
# Usar la misma clave que local SOLO si se quieren compartir credenciales entre entornos
# Recomendado: generar una clave exclusiva para staging
# openssl rand -hex 32
N8N_ENCRYPTION_KEY=CAMBIAR_POR_CLAVE_STAGING_REAL

# --- STAGING URLS ---
N8N_EDITOR_BASE_URL=http://<IP_R720>:5678
WEBHOOK_URL=http://<IP_R720>:5678/

# --- IMAGEN DOCKER ---
# Usar imagen oficial para staging (sin necesidad de ECR)
ECR_REGISTRY=docker.n8n.io/n8nio/n8n
TAG=latest

# --- THREAT INTELLIGENCE (requerido para compose staging) ---
THREAT_DB_USER=delcop_threat
THREAT_DB_PASSWORD=CAMBIAR_PASSWORD_THREAT_DB
REDIS_PASSWORD=CAMBIAR_PASSWORD_REDIS
WAZUH_INDEXER_URL=https://<IP_INDEXER_WAZUH>:9200
# Valor esperado: "Basic <base64(usuario:password)>"
WAZUH_INDEXER_BASIC_AUTH=

# --- SSH DEPLOY (usado por Makefile desde local) ---
# Estos valores se usan en: make deploy-staging
STAGING_HOST=<IP_o_hostname_R720>
STAGING_USER=<usuario_ssh_R720>
STAGING_PATH=/srv/n8n-platform
