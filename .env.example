# .env.example — Configuración para n8n Platform

# --- CONFIGURACIÓN GENERAL ---
# Zona horaria (ej: America/Bogota, UTC)
TZ=America/Bogota
GENERIC_TIMEZONE=America/Bogota

# --- ENTORNO LOCAL (Docker Compose) ---
# Puerto donde n8n será accesible localmente
N8N_PORT=5678

# --- SEGURIDAD (CRÍTICO) ---
# Generar con: openssl rand -hex 32
N8N_ENCRYPTION_KEY=cambiar_por_una_llave_real_en_produccion

# --- STAGING (Dell R720) ---
# URL base para el editor y webhooks en staging
N8N_EDITOR_BASE_URL=http://staging.delcop.com:5678
WEBHOOK_URL=http://staging.delcop.com:5678/

# --- PRODUCCIÓN (AWS ECS / RDS) ---
# Datos de la base de datos PostgreSQL en RDS
RDS_HOST=n8n-db.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
RDS_USER=n8n_user
RDS_PASSWORD=password_seguro_rds

# Configuración de AWS para ECR y logs
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
TAG=latest

# --- THREAT INTELLIGENCE DB (PostgreSQL separada de n8n) ---
THREAT_DB_USER=delcop_threat
THREAT_DB_PASSWORD=cambiar_password_threat_db
THREAT_DB_HOST_PORT=5433
REDIS_PASSWORD=cambiar_password_redis
REDIS_HOST_PORT=6379

# --- THREAT INTELLIGENCE SOURCES ---
FORTIGATE_HOST=https://192.168.1.1:443
FORTIGATE_API_KEY=
WAZUH_API_URL=https://wazuh-manager:55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=
ZABBIX_API_URL=http://zabbix-server/api_jsonrpc.php
ZABBIX_API_TOKEN=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=

# --- NOTIFICACIONES ---
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
ALERT_EMAIL_TO=seguridad@delcop.com.co
ALERT_EMAIL_FROM=n8n-threatintel@delcop.com.co

# --- OTROS (OPCIONAL) ---
# Registro de Docker (ECR u otro)
ECR_REGISTRY=n8nio/n8n
# Host de Redis para modo Queue (si se activa HA)
REDIS_HOST=localhost
