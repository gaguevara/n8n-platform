# =============================================================================
# n8n Platform - Git Ignore
# =============================================================================

# Environment files con secrets
.env
.env.local
.env.staging
.env.prod

# Datos persistentes (contiene credenciales encriptadas)
data/
!data/.gitkeep

# Archivos compartidos temporales
shared-files/
!shared-files/.gitkeep

# Logs
*.log
logs/
!docs/logs/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# IDE / Editor
.vscode/*
!.vscode/tasks.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Docker
.docker/

# Backups
*.backup
*.bak
*.tar.gz
backups/

# Node (si se instalan dependencias localmente)
node_modules/

# Temporal
tmp/
temp/
*.tmp

# Framework ZIP (no versionar el distribuible)
*.zip

# AWS credentials (nunca deben estar en repo)
.aws/
credentials

# Python (framework multi-agente engine)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
.mypy_cache/

# Claude Code (session-specific, not project config)
.claude/settings.local.json

# Community skills (installed per-project via npx skills add)
.agent/
.agents/
.continue/
skills-lock.json
# Community skill symlinks in .claude/skills/ (installed, not framework-native)
.claude/skills/docker-security-guide
.claude/skills/aws-ecs-fargate
.claude/skills/postgres-patterns

# Secrets extras (nunca commitear)
*.pem
*.key
credentials.json
secrets.yaml
