# ===== Framework Multi-Agente .gitignore =====

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Claude Code (session-specific, not project config)
.claude/settings.local.json

# Community skills (installed per-project via npx skills add, not part of framework base)
.agents/
.codebuddy/
.continue/
skills-lock.json
# Symlinks created by skills.sh in .claude/skills/ — add community skill names here
# Our own skills (adapt-project, validate-change, etc.) are NOT listed and ARE tracked
.claude/skills/python-best-practices
.claude/skills/code-review-security
.claude/skills/systematic-debugging
.claude/skills/verification-before-completion
.claude/skills/subagent-driven-development

# Distribution zips (generated, not tracked)
multiagent-framework-v*.zip

# Secrets (never commit)
.env
.env.*
*.pem
*.key
credentials.json
secrets.yaml
.multiagent/.watch.*
.claude/scheduled_tasks.lock
