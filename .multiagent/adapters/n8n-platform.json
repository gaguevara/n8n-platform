{
  "project_name": "n8n-platform",
  "display_name": "n8n Platform - DELCOP",
  "framework_version": "4.7",
  "agents": [
    {
      "id": "CLAUDE",
      "role": "governor",
      "log": "docs/logs/CLAUDE_LOG.md"
    },
    {
      "id": "CODEX",
      "role": "implementer",
      "log": "docs/logs/CODEX_LOG.md"
    },
    {
      "id": "GEMINI",
      "role": "researcher",
      "log": "docs/logs/GEMINI_LOG.md"
    }
  ],
  "paths": {
    "log_index": "docs/governance/LOG_INDEX.md",
    "context": "docs/governance/CONTEXT.md",
    "project_rules": "docs/governance/PROJECT_RULES.md",
    "agent_roles": "docs/governance/AGENT_ROLES.md"
  },
  "validators": {
    ".json": "python -m json.tool {file}",
    ".yml": "python -c \"import yaml; yaml.safe_load(open('{file}'))\"",
    ".yaml": "python -c \"import yaml; yaml.safe_load(open('{file}'))\"",
    ".sh": "bash -n {file}",
    ".md": "python -c \"import os,sys; sys.exit(0 if os.path.getsize('{file}')>0 else 1)\""
  },
  "windows_fallbacks": {
    "sync-index": "powershell -ExecutionPolicy Bypass -File .multiagent/core/sync_index.ps1",
    "pre-commit": "python -m pre_commit run --all-files",
    "hadolint": "docker run --rm -i hadolint/hadolint < Dockerfile",
    "shellcheck": "docker run --rm -i koalaman/shellcheck-alpine"
  },
  "stack": {
    "primary": "n8n (Node.js/Docker)",
    "languages": [
      "JSON",
      "Shell"
    ],
    "containers": "Docker",
    "ci_cd": "pre-commit + Makefile",
    "environments": [
      "local",
      "staging",
      "production"
    ],
    "cloud": "AWS ECS Fargate",
    "databases": {
      "local": "SQLite",
      "production": "PostgreSQL RDS"
    },
    "observability": "Structured Logs (Markdown)"
  },
  "log_entry_pattern": "## ENTRADA-{number}",
  "task_file_pattern": "SPEC_*.md",
  "state": "brownfield",
  "auto_validate": {
    "enabled": true,
    "interval_minutes": 3,
    "round_counter": 9,
    "baseline": {
      "CLAUDE": 0,
      "CODEX": 0,
      "GEMINI": 0
    },
    "on_new_entry": [
      "verify_files",
      "commit",
      "sync_index",
      "notify"
    ],
    "hallucination_check": true,
    "auto_commit": true,
    "notify": "stdout",
    "subagent_pattern": "SUB-{AGENT}-{N}",
    "deadman_interval": 5,
    "role_boundaries": {
      "CLAUDE": [
        "docs/governance/",
        "docs/sdlc/",
        "SESSION_BOOTSTRAP.md",
        "CLAUDE.md"
      ],
      "CODEX": [
        ".multiagent/core/",
        ".multiagent/tests/",
        ".multiagent/adapters/",
        "app/workflows/",
        "app/code-nodes/",
        "infra/",
        "scripts/",
        "ops/",
        ".env.example",
        ".env.staging.example",
        "AGENTS.md",
        "GEMINI.md",
        "*.py",
        "pyproject.toml"
      ],
      "GEMINI": [
        "docs/knowledge/",
        "docs/architecture/",
        "docs/sdlc/",
        "docs/skills/",
        "docs/governance/ONBOARDING.md",
        "docs/governance/FRAMEWORK_CAPABILITIES.md",
        "docs/PHASE1_SUMMARY.md"
      ]
    },
    "shared_zones": [
      "docs/logs/",
      "docs/governance/CONTEXT.md",
      "docs/governance/LOG_INDEX.md",
      "docs/reviews/"
    ]
  }
}
